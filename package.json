        "express": "^5.2.1",
        "express-list-endpoints": "^7.1.1",
        "express-rate-limit": "^8.3.1",
        "helmet": "^8.1.0",
        "joi": "^18.0.2",
        "jsonwebtoken": "^9.0.3",
        "multer": "^2.1.1",
        "pg": "^8.20.0",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "winston": "^3.19.0"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.4",
        "@types/react": "^19.2.14",
