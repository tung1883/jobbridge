        "test:be": "npm run test --workspace backend",
        "test:be:watch": "npm run test:watch --workspace backend",
        "test:be:cover": "npm run test:cover --workspace backend",
        "gendocs": "npm run gendocs --workspace backend",
        "dev:fe": "npm run dev --workspace frontend",
        "build:fe": "npm run build --workspace frontend",
        "lint:fe": "npm run lint --workspace frontend",
        "preview:fe": "npm run preview --workspace frontend",
        "dev:all": "concurrently \"npm run dev:be\" \"npm run dev:fe\"",
        "start:all:prod": "concurrently \"npm run start:be\" \"npm run build:fe\""
